# App
NODE_ENV=development
WEB_PORT=3000
API_PORT=4000
WEB_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# Local PostgreSQL (matches docker-compose.yml)
DATABASE_URL=postgresql://projectbowl:projectbowl@localhost:5432/projectbowl?schema=public

# Auth setup (placeholder only; replace locally)
JWT_ACCESS_SECRET=replace-me
JWT_REFRESH_SECRET=replace-me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Admin seed setup (placeholder only; replace locally)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-me
ADMIN_NAME=ProjectBowl Admin

# AI setup (placeholder only; OpenRouter key is server-side only)
OPENROUTER_API_KEY=replace-me
OPENROUTER_MODEL=openai/gpt-4o-mini

# Future upload setup (placeholder only; not implemented yet)
CLOUDINARY_CLOUD_NAME=replace-me
CLOUDINARY_API_KEY=replace-me
CLOUDINARY_API_SECRET=replace-me
