# ProjectBowl — Vercel + Supabase
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase (required for dashboard/auth/live data)
NEXT_PUBLIC_SUPABASE_URL=replace-me
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-me
SUPABASE_SERVICE_ROLE_KEY=replace-me

# OpenRouter AI (server-side only, optional until AI Studio is used)
OPENROUTER_API_KEY=replace-me
OPENROUTER_MODEL=openai/gpt-4o-mini

# Cloudinary uploads (server-side secrets; optional until upload endpoint is implemented)
CLOUDINARY_CLOUD_NAME=replace-me
CLOUDINARY_API_KEY=replace-me
CLOUDINARY_API_SECRET=replace-me
CLOUDINARY_UPLOAD_FOLDER=projectbowl

# GitHub public repos (shown on the portfolio's "Latest GitHub Activity" section)
# GITHUB_USERNAME defaults to Radian-File when unset.
# GITHUB_TOKEN is optional: public repos work without it, but a token raises
# the API rate limit. Use a fine-grained/classic PAT with read-only scope.
GITHUB_USERNAME=Radian-File
GITHUB_TOKEN=
